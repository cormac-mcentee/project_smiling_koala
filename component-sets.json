    {
      "id": "componentset_1779500000011",
      "name": "Specialist Process Components",
      "description": "Components requiring more complex wiring conventions.",
      "components": [
        {
          "id": "component_1779500000007",
          "name": "Heat Exchanger",
          "colour": "#14b8a6",
          "variables": [
            {
              "id": "var_he_process_flowing",
              "name": "process_flowing",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_he_service_flowing",
              "name": "service_flowing",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_he_process_temp_in",
              "name": "process_temp_in",
              "type": "number",
              "defaultValue": 20
            },
            {
              "id": "var_he_service_temp_in",
              "name": "service_temp_in",
              "type": "number",
              "defaultValue": 60
            },
            {
              "id": "var_he_heat_transfer_active",
              "name": "heat_transfer_active",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_he_process_temp_out",
              "name": "process_temp_out",
              "type": "number",
              "defaultValue": 20
            },
            {
              "id": "var_he_service_temp_out",
              "name": "service_temp_out",
              "type": "number",
              "defaultValue": 20
            },
            {
              "id": "var_he_fault",
              "name": "fault",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_he_process_fluid_type",
              "name": "process_fluid_type",
              "type": "string",
              "defaultValue": ""
            },
            {
              "id": "var_he_service_fluid_type",
              "name": "service_fluid_type",
              "type": "string",
              "defaultValue": ""
            }
          ],
          "actions": [
            {
              "id": "action_he_update_flow",
              "name": "update_flow",
              "script": "IF SUP(0).fluid_flowing THEN\n  SET self.process_flowing = true\n  SET self.process_temp_in = SUP(0).temperature\n  SET self.process_fluid_type = SUP(0).fluid_type\nELSE\n  SET self.process_flowing = false\n  SET self.process_fluid_type = \"\"\nEND\nIF SUP(1).fluid_flowing THEN\n  SET self.service_flowing = true\n  SET self.service_temp_in = SUP(1).temperature\n  SET self.service_fluid_type = SUP(1).fluid_type\nELSE\n  SET self.service_flowing = false\n  SET self.service_fluid_type = \"\"\nEND\nIF self.process_flowing AND self.service_flowing THEN\n  SET self.heat_transfer_active = true\n  SET self.process_temp_out = 80\n  SET self.service_temp_out = 40\n  SET self.fault = false\nELSE\n  SET self.heat_transfer_active = false\n  IF self.process_flowing THEN\n    SET self.process_temp_out = self.process_temp_in\n    SET self.service_temp_out = 20\n    SET self.fault = true\n  ELSE\n    SET self.process_temp_out = self.process_temp_in\n    SET self.service_temp_out = self.service_temp_in\n    SET self.fault = false\n  END\nEND\nIF self.process_flowing THEN\n  SET ALLINF(cold_outlet).fluid_present = true\n  SET ALLINF(cold_outlet).flow_rate = SUP(0).flow_rate\n  SET ALLINF(cold_outlet).temperature = self.process_temp_out\n  SET ALLINF(cold_outlet).fluid_type = self.process_fluid_type\nELSE\n  SET ALLINF(cold_outlet).fluid_present = false\n  SET ALLINF(cold_outlet).flow_rate = 0\n  SET ALLINF(cold_outlet).temperature = 20\n  SET ALLINF(cold_outlet).fluid_type = \"\"\nEND\nIF self.service_flowing THEN\n  SET ALLINF(hot_outlet).fluid_present = true\n  SET ALLINF(hot_outlet).flow_rate = SUP(1).flow_rate\n  SET ALLINF(hot_outlet).temperature = self.service_temp_out\n  SET ALLINF(hot_outlet).fluid_type = self.service_fluid_type\nELSE\n  SET ALLINF(hot_outlet).fluid_present = false\n  SET ALLINF(hot_outlet).flow_rate = 0\n  SET ALLINF(hot_outlet).temperature = 20\n  SET ALLINF(hot_outlet).fluid_type = \"\"\nEND"
            },
            {
              "id": "action_he_reset_fault",
              "name": "reset_fault",
              "script": "SET self.fault = false"
            }
          ],
          "listeners": [
            {
              "id": "listener_he_sup0_on",
              "condition": "SUP(0).fluid_flowing",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_he_sup0_off",
              "condition": "SUP(0).fluid_flowing == false",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_he_sup1_on",
              "condition": "SUP(1).fluid_flowing",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_he_sup1_off",
              "condition": "SUP(1).fluid_flowing == false",
              "script": "CALL self.update_flow"
            }
          ],
          "outlets": [
            {
              "id": "cold_outlet",
              "name": "Cold Outlet (Process Out)"
            },
            {
              "id": "hot_outlet",
              "name": "Hot Outlet (Service Out)"
            }
          ],
          "superiors": [],
          "created": "2026-05-22T00:00:00.007Z"
        },
        {
          "id": "component_he_outlet_valve",
          "name": "HE Outlet Valve",
          "variables": [
            {
              "id": "var_valve_open",
              "name": "open",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_valve_fluid_present",
              "name": "fluid_present",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_valve_fluid_flowing",
              "name": "fluid_flowing",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_valve_flow_rate",
              "name": "flow_rate",
              "type": "number",
              "defaultValue": 0
            },
            {
              "id": "var_hov_temperature",
              "name": "temperature",
              "type": "number",
              "defaultValue": 20
            },
            {
              "id": "var_hov_fluid_type",
              "name": "fluid_type",
              "type": "string",
              "defaultValue": ""
            }
          ],
          "actions": [
            {
              "id": "action_hov_toggle",
              "name": "on_toggle",
              "script": "IF self.open THEN\n  SET self.open = false\nELSE\n  SET self.open = true\nEND\nCALL self.update_flow"
            },
            {
              "id": "action_hov_update_flow",
              "name": "update_flow",
              "script": "IF self.open AND self.fluid_present THEN\n  SET self.fluid_flowing = true\nELSE\n  SET self.fluid_flowing = false\n  SET self.flow_rate = 0\n  SET self.temperature = 20\n  SET self.fluid_type = \"\"\nEND"
            }
          ],
          "listeners": [
            {
              "id": "listener_hov_ready",
              "condition": "self.fluid_present AND self.open",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_hov_present_off",
              "condition": "self.fluid_present == false",
              "script": "SET self.fluid_flowing = false\nSET self.flow_rate = 0\nSET self.temperature = 20\nSET self.fluid_type = \"\""
            },
            {
              "id": "listener_hov_closed",
              "condition": "self.open == false",
              "script": "SET self.fluid_flowing = false\nSET self.flow_rate = 0\nSET self.temperature = 20\nSET self.fluid_type = \"\""
            },
            {
              "id": "listener_hov_signal_blocked",
              "condition": "self.open == false AND ANYSUP.fluid_flowing",
              "script": "SET ALLSUP.blocked = true"
            },
            {
              "id": "listener_hov_signal_unblocked",
              "condition": "self.open",
              "script": "SET ALLSUP.blocked = false"
            }
          ],
