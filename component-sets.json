          ],
          "actions": [
            {
              "id": "action_cv_on_toggle",
              "name": "on_toggle",
              "script": "IF self.open THEN\n  SET self.open = false\nELSE\n  SET self.open = true\nEND\nCALL self.update_flow"
            },
            {
              "id": "action_cv_update_flow",
              "name": "update_flow",
              "script": "IF self.open AND self.opening > 0 THEN\n  IF ANYSUP.fluid_present THEN\n    SET self.fluid_present = true\n  ELSE\n    SET self.fluid_present = false\n  END\n  IF ANYSUP.fluid_flowing THEN\n    SET self.fluid_flowing = true\n    SET self.flow_rate = SUMSUP.flow_rate * self.opening / 100\n    SET self.temperature = SUMSUP.temperature\n    SET self.fluid_type = SUP(0).fluid_type\n  ELSE\n    SET self.fluid_flowing = false\n    SET self.flow_rate = 0\n    SET self.temperature = 20\n    SET self.fluid_type = \"\"\n  END\nELSE\n  SET self.fluid_present = false\n  SET self.fluid_flowing = false\n  SET self.flow_rate = 0\n  SET self.temperature = 20\n  SET self.fluid_type = \"\"\nEND"
            }
          ],
          "listeners": [
            {
              "id": "listener_cv_flow_on",
              "condition": "ANYSUP.fluid_flowing",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_cv_flow_off",
              "condition": "ANYSUP.fluid_flowing == false",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_cv_present_on",
              "condition": "ANYSUP.fluid_present",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_cv_present_off",
              "condition": "ANYSUP.fluid_present == false",
              "script": "SET self.fluid_present = false\nSET self.fluid_flowing = false\nSET self.flow_rate = 0\nSET self.temperature = 20\nSET self.fluid_type = \"\""
            }
          ],
          "superiors": [],
          "created": "2026-05-24T00:00:00.001Z"
