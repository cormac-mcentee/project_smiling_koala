              "type": "string",
              "defaultValue": ""
            }
          ],
          "actions": [
            {
              "id": "action_valve_on_toggle",
              "name": "on_toggle",
              "script": "IF self.open THEN\n  SET self.open = false\nELSE\n  SET self.open = true\nEND\nCALL self.update_flow"
            },
            {
              "id": "action_valve_update_flow",
              "name": "update_flow",
              "script": "IF self.open THEN\n  IF ANYSUP.fluid_present THEN\n    SET self.fluid_present = true\n  ELSE\n    SET self.fluid_present = false\n  END\n  IF ANYSUP.fluid_flowing THEN\n    SET self.fluid_flowing = true\n    SET self.flow_rate = SUMSUP.flow_rate\n    SET self.temperature = SUMSUP.temperature\n    SET self.fluid_type = SUP(0).fluid_type\n  ELSE\n    SET self.fluid_flowing = false\n    SET self.flow_rate = 0\n    SET self.temperature = 20\n    SET self.fluid_type = \"\"\n  END\nELSE\n  SET self.fluid_present = false\n  SET self.fluid_flowing = false\n  SET self.flow_rate = 0\n  SET self.temperature = 20\n  SET self.fluid_type = \"\"\nEND"
            }
          ],
          "listeners": [
            {
              "id": "listener_valve_flow_on",
              "condition": "ANYSUP.fluid_flowing",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_valve_flow_off",
              "condition": "ANYSUP.fluid_flowing == false",
              "script": "SET self.fluid_flowing = false\nSET self.flow_rate = 0\nSET self.temperature = 20\nSET self.fluid_type = \"\""
            },
            {
              "id": "listener_valve_pressure_on",
              "condition": "ANYSUP.fluid_present",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_valve_pressure_off",
              "condition": "ANYSUP.fluid_present == false",
              "script": "SET self.fluid_present = false\nSET self.fluid_flowing = false\nSET self.flow_rate = 0\nSET self.temperature = 20\nSET self.fluid_type = \"\""
            },
            {
              "id": "listener_valve_signal_blocked",
              "condition": "self.open == false AND ANYSUP.fluid_flowing",
              "script": "SET ALLSUP.blocked = true"
            },
            {
              "id": "listener_valve_signal_unblocked",
              "condition": "self.open",
              "script": "SET ALLSUP.blocked = false"
            }
          ],
          "superiors": [],
          "created": "2026-05-21T21:34:05.576Z"
        },
        {
