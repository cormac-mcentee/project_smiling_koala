          ],
          "actions": [
            {
              "id": "action_pipe_update_flow",
              "name": "update_flow",
              "script": "IF ANYSUP.fluid_flowing THEN\n  IF self.blocked THEN\n    SET self.fluid_present = true\n    SET self.fluid_flowing = false\n    SET self.flow_rate = 0\n    SET self.fluid_type = \"\"\n    SET self.pressure_drop = 0\n  ELSE\n    SET self.fluid_present = true\n    SET self.fluid_flowing = true\n    SET self.flow_rate = SUMSUP.flow_rate\n    SET self.temperature = SUMSUP.temperature\n    SET self.fluid_type = SUP(0).fluid_type\n    SET self.pressure_drop = self.resistance * self.flow_rate ^ 2 + 9810 * self.elevation_change\n  END\nELSE\n  SET self.fluid_flowing = false\n  SET self.flow_rate = 0\n  SET self.temperature = 20\n  SET self.fluid_type = \"\"\n  SET self.pressure_drop = 0\n  IF ANYSUP.fluid_present THEN\n    SET self.fluid_present = true\n  ELSE\n    SET self.fluid_present = false\n  END\nEND"
            }
          ],
          "listeners": [
            {
              "id": "listener_pipe_flow_on",
              "condition": "ANYSUP.fluid_flowing",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_pipe_flow_off",
              "condition": "ANYSUP.fluid_flowing == false",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_pipe_present_on",
              "condition": "ANYSUP.fluid_present",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_pipe_present_off",
              "condition": "ANYSUP.fluid_present == false",
              "script": "SET self.fluid_present = false\nSET self.fluid_flowing = false\nSET self.flow_rate = 0\nSET self.temperature = 20\nSET self.fluid_type = \"\"\nSET self.pressure_drop = 0"
            },
            {
              "id": "listener_pipe_blocked",
              "condition": "self.blocked",
              "script": "SET self.fluid_flowing = false\nSET self.flow_rate = 0\nSET self.fluid_type = \"\"\nSET self.pressure_drop = 0"
            }
          ],
          "superiors": [],
          "created": "2026-05-24T00:00:00.000Z"
