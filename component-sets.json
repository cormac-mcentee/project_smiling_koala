              "defaultValue": ""
            }
          ],
          "actions": [
            {
              "id": "action_ecv_update_opening",
              "name": "update_opening",
              "script": "IF self.powered THEN\n  SET self.opening = self.signal\nELSE\n  IF self.fail_open THEN\n    SET self.opening = 100\n  ELSE\n    SET self.opening = 0\n  END\nEND\nCALL self.update_flow"
            },
            {
              "id": "action_ecv_update_flow",
              "name": "update_flow",
              "script": "IF self.opening > 0 THEN\n  IF ANYSUP.fluid_present THEN\n    SET self.fluid_present = true\n  ELSE\n    SET self.fluid_present = false\n  END\n  IF ANYSUP.fluid_flowing THEN\n    SET self.fluid_flowing = true\n    SET self.flow_rate = SUMSUP.flow_rate * self.opening / 100\n    SET self.temperature = SUMSUP.temperature\n    SET self.fluid_type = SUP(0).fluid_type\n  ELSE\n    SET self.fluid_flowing = false\n    SET self.flow_rate = 0\n    SET self.temperature = 20\n    SET self.fluid_type = \"\"\n  END\nELSE\n  SET self.fluid_present = false\n  SET self.fluid_flowing = false\n  SET self.flow_rate = 0\n  SET self.temperature = 20\n  SET self.fluid_type = \"\"\nEND"
            }
          ],
          "listeners": [
            {
              "id": "listener_ecv_flow_on",
              "condition": "ANYSUP.fluid_flowing",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_ecv_flow_off",
              "condition": "ANYSUP.fluid_flowing == false",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_ecv_present_on",
              "condition": "ANYSUP.fluid_present",
              "script": "CALL self.update_flow"
            },
            {
              "id": "listener_ecv_present_off",
              "condition": "ANYSUP.fluid_present == false",
              "script": "SET self.fluid_present = false\nSET self.fluid_flowing = false\nSET self.flow_rate = 0\nSET self.temperature = 20\nSET self.fluid_type = \"\""
            },
            {
              "id": "listener_ecv_powered_on",
              "condition": "self.powered",
              "script": "CALL self.update_opening"
            },
            {
              "id": "listener_ecv_powered_off",
              "condition": "self.powered == false",
              "script": "CALL self.update_opening"
            },
            {
              "id": "listener_ecv_supply_on",
              "condition": "ANYSUP.energised",
              "script": "SET self.powered = true\nCALL self.update_opening"
            },
            {
              "id": "listener_ecv_supply_off",
              "condition": "ANYSUP.energised == false",
              "script": "SET self.powered = false\nCALL self.update_opening"
            }
          ],
