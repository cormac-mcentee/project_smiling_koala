          "actions": [
            {
              "id": "action_heater_on_toggle",
              "name": "on_toggle",
              "script": "IF self.active THEN\n  SET self.active = false\n  SET self.heating = false\n  SET self.temperature = 20\n  SET self.fault = false\nELSE\n  IF ANYSUP.fluid_flowing THEN\n    SET self.active = true\n    SET self.fault = false\n  ELSE\n    SET self.fault = true\n  END\nEND\nCALL self.update_flow"
            },
            {
              "id": "action_heater_update_flow",
              "name": "update_flow",
              "script": "IF ANYSUP.fluid_flowing THEN\n  SET self.fluid_present = true\n  SET self.fluid_flowing = true\n  SET self.flow_rate = SUMSUP.flow_rate\n  SET self.fluid_type = SUP(0).fluid_type\n  IF self.active THEN\n    SET self.heating = true\n    SET self.temperature = 80\n  ELSE\n    SET self.heating = false\n    SET self.temperature = SUMSUP.temperature\n  END\nELSE\n  SET self.fluid_present = false\n  SET self.fluid_flowing = false\n  SET self.flow_rate = 0\n  SET self.heating = false\n  SET self.temperature = 20\n  SET self.fluid_type = \"\"\n  IF self.active THEN\n    SET self.fault = true\n  END\nEND"
            },
            {
              "id": "action_heater_reset",
              "name": "reset_fault",
              "script": "SET self.fault = false"
            }
          ],
          "listeners": [
