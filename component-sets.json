        {
          "id": "component_1779500000004",
          "name": "Tank",
          "colour": "#3b82f6",
          "variables": [
            {
              "id": "var_tank_fluid_present",
              "name": "fluid_present",
              "type": "boolean",
              "defaultValue": true
            },
            {
              "id": "var_tank_level",
              "name": "level",
              "type": "number",
              "defaultValue": 100
            },
            {
              "id": "var_tank_receiving",
              "name": "receiving",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_tank_temperature",
              "name": "temperature",
              "type": "number",
              "defaultValue": 20
            },
            {
              "id": "var_tank_fluid_type",
              "name": "fluid_type",
              "type": "string",
              "defaultValue": ""
            },
            {
              "id": "var_tank_low_threshold",
              "name": "low_threshold",
              "type": "number",
              "defaultValue": 20
            },
            {
              "id": "var_tank_high_threshold",
              "name": "high_threshold",
              "type": "number",
              "defaultValue": 80
            },
            {
              "id": "var_tank_level_low",
              "name": "level_low",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_tank_level_high",
              "name": "level_high",
              "type": "boolean",
              "defaultValue": false
            }
          ],
          "actions": [
            {
              "id": "action_tank_update",
              "name": "update",
              "script": "IF self.level > 0 THEN\n  SET self.fluid_present = true\nELSE\n  SET self.fluid_present = false\nEND\nIF self.level <= self.low_threshold THEN\n  SET self.level_low = true\nELSE\n  SET self.level_low = false\nEND\nIF self.level >= self.high_threshold THEN\n  SET self.level_high = true\nELSE\n  SET self.level_high = false\nEND"
            },
            {
              "id": "action_tank_tick",
              "name": "tick",
              "script": "IF self.receiving THEN\n  SET self.level = MIN(self.level + 25, 100)\n  CALL self.update\nEND"
            }
          ],
          "listeners": [
            {
              "id": "listener_tank_inflow_on",
              "condition": "ANYSUP.fluid_flowing",
              "script": "SET self.receiving = true\nSET self.temperature = SUMSUP.temperature\nSET self.fluid_type = SUP(0).fluid_type"
            },
            {
              "id": "listener_tank_inflow_off",
              "condition": "ANYSUP.fluid_flowing == false",
              "script": "SET self.receiving = false\nSET self.fluid_type = \"\""
            }
          ],
          "superiors": [],
          "created": "2026-05-22T00:00:00.004Z"
        },
        {
          "id": "component_1779500000001",
          "name": "Pump",
          "colour": "#f59e0b",
          "variables": [
            {
              "id": "var_pump_running",
              "name": "running",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_pump_fluid_present",
              "name": "fluid_present",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_pump_fluid_flowing",
              "name": "fluid_flowing",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_pump_flow_rate",
              "name": "flow_rate",
              "type": "number",
              "defaultValue": 0
            },
            {
              "id": "var_pump_temperature",
              "name": "temperature",
              "type": "number",
              "defaultValue": 20
            },
            {
              "id": "var_pump_fault",
              "name": "fault",
              "type": "boolean",
              "defaultValue": false
            },
            {
              "id": "var_pump_fluid_type",
              "name": "fluid_type",
              "type": "string",
              "defaultValue": ""
            }
          ],
          "actions": [
            {
              "id": "action_pump_on_toggle",
              "name": "on_toggle",
              "script": "IF self.running THEN\n  SET self.running = false\n  SET self.fluid_present = false\n  SET self.fluid_flowing = false\n  SET self.flow_rate = 0\n  SET self.temperature = 20\n  SET self.fluid_type = \"\"\nELSE\n  IF ANYSUP.fluid_present THEN\n    SET self.running = true\n    SET self.fluid_present = true\n    SET self.fluid_flowing = true\n    SET self.flow_rate = 100\n    SET self.temperature = SUMSUP.temperature\n    SET self.fluid_type = SUP(0).fluid_type\n    SET self.fault = false\n  ELSE\n    SET self.fault = true\n  END\nEND"
            },
            {
              "id": "action_pump_reset",
              "name": "reset_fault",
              "script": "SET self.fault = false"
            }
          ],
          "listeners": [
            {
              "id": "listener_pump_dry_run",
              "condition": "ANYSUP.fluid_present == false",
              "script": "IF self.running THEN\n  SET self.fault = true\n  SET self.running = false\n  SET self.fluid_present = false\n  SET self.fluid_flowing = false\n  SET self.flow_rate = 0\n  SET self.temperature = 20\n  SET self.fluid_type = \"\"\nEND"
            },
            {
              "id": "listener_pump_running_on",
              "condition": "self.running",
              "script": "SET self.fluid_present = true\nSET self.fluid_flowing = true\nSET self.flow_rate = 100\nSET self.temperature = SUMSUP.temperature\nSET self.fluid_type = SUP(0).fluid_type"
            },
            {
              "id": "listener_pump_running_off",
              "condition": "self.running == false",
              "script": "SET self.fluid_present = false\nSET self.fluid_flowing = false\nSET self.flow_rate = 0\nSET self.temperature = 20\nSET self.fluid_type = \"\""
            },
            {
              "id": "listener_pump_dead_head",
              "condition": "self.running AND ANYINF.blocked",
              "script": "SET self.fault = true\nSET self.running = false\nSET self.fluid_flowing = false\nSET self.flow_rate = 0\nSET self.temperature = 20\nSET self.fluid_type = \"\""
            }
          ],
          "superiors": [],
          "created": "2026-05-22T00:00:00.001Z"
        },
        {
