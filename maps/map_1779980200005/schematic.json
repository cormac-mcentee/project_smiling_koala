  "landmarks": [
    {
      "id": "lm_e11_01",
      "type": "text",
      "x": 0,
      "y": -160,
      "content": "Mains path (top): PS1 supplies 415 V AC. SW_Mains closes the circuit. The splitter (SPL1) feeds AC directly to Junction JNC1, which powers ML1.",
      "fontSize": 12,
      "fontWeight": "normal",
      "colour": "#94a3b8",
      "layer": "above_schematic"
    },
    {
      "id": "lm_e11_02",
      "type": "text",
      "x": 420,
      "y": -160,
      "content": "Battery loop (bottom): SPL1 also feeds REC1 (Rectifier), which converts AC to DC to charge Battery1. When mains fails, enable discharge mode — Battery1 feeds INV1 (Inverter), which converts DC back to stable 50 Hz AC entering JNC1 from below.",
      "fontSize": 12,
      "fontWeight": "normal",
      "colour": "#94a3b8",
      "layer": "above_schematic"
    }
  ]
