    {
      "id": "lm_e14_01",
      "type": "text",
      "x": 0,
      "y": -240,
      "content": "WT1: rated 1500 rpm, cut-in 15%, cut-out 85%. WT2: rated 1200 rpm, cut-in 10%, cut-out 80%. Each turbine has a step-up transformer (TX×2). Both chains combine at BUS_A.",
      "fontSize": 12,
      "fontWeight": "normal",
      "colour": "#94a3b8",
      "layer": "above_schematic"
    },
    {
      "id": "lm_e14_02",
      "type": "text",
      "x": 700,
      "y": -100,
      "content": "Battery charges automatically when BUS_A is live. To export during a wind lull, press Toggle Discharge — battery outputs stable 415 V from stored charge. Battery depletes at 0.5%/tick in discharge mode.",
      "fontSize": 12,
      "fontWeight": "normal",
      "colour": "#94a3b8",
      "layer": "above_schematic"
    }
  ]
