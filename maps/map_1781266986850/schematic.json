  "landmarks": [
    {
      "id": "lm_coal_01",
      "type": "text",
      "x": 107,
      "y": 47,
      "content": "Steam circuit (Rankine cycle): ECV1 admits feedwater → JUN1 collects return flow → TOR1 pumps to VAP1 (boiler) → FLU1–FLU3 turbines extract work as steam expands → SPL1 splits condensate to V1 (OUT1 return) and V2 (JUN1 recirculation).",
      "fontSize": 11,
      "fontWeight": "normal",
      "colour": "#94a3b8",
      "layer": "above_schematic"
    },
    {
      "id": "lm_coal_02",
      "type": "text",
      "x": 63,
      "y": 635,
      "content": "Mechanical drive: DRI1 motor → SHA1 → TOR1 shaft input. FLU1/FLU2/FLU3 shaft outputs → SHA2/SHA3/SHA4 → ADS1 hub (sums turbine torques) → SHA5 → GEN1.",
      "fontSize": 11,
      "fontWeight": "normal",
      "colour": "#94a3b8",
      "layer": "above_schematic"
    },
    {
      "id": "lm_coal_03",
      "type": "text",
      "x": 166,
      "y": 812,
      "content": "Electrical loop: PS1 provides startup power via FUS1 → WIR4 junction. WIR3 splitter feeds SWI1 (ECV1 control) and SWI2 (DRI1 motor). Once GEN1 is online it feeds back through TRA1 → WIR4 (self-sustaining loop) and exports via TRA2 → GRI1.",
      "fontSize": 11,
      "fontWeight": "normal",
      "colour": "#94a3b8",
      "layer": "above_schematic"
    }
  ]
}